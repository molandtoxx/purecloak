          !context_provider_wrapper->ContextProvider().IsContextLost();
 }
 
+// PureCloak: inject deterministic noise into canvas pixel data to prevent
+// canvas fingerprinting. Only ~0.1% of pixels are modified by ±1 per RGB
+// channel, making the change visually imperceptible.
+void PureCloakCanvasNoise(purecloak::PureCloakNoiseTag, SkPixmap& pixmap) {
+  for (int y = 0; y < pixmap.height(); ++y) {
+    for (int x = 0; x < pixmap.width(); ++x) {
+      if ((x * 1009 + y * 3049) % 997 != 0) {
+        continue;
+      }
+      uint8_t* pixel = static_cast<uint8_t*>(pixmap.writable_addr(x, y));
+      int index = y * pixmap.width() + x;
+      int r_noise = purecloak::PureCloakNoise(0, index);
+      int g_noise = purecloak::PureCloakNoise(0, index + 1);
+      int b_noise = purecloak::PureCloakNoise(0, index + 2);
+      pixel[0] = static_cast<uint8_t>(std::clamp(
+          static_cast<int>(pixel[0]) + ((r_noise > 0) - (r_noise < 0)), 0,
+          255));
+      pixel[1] = static_cast<uint8_t>(std::clamp(
+          static_cast<int>(pixel[1]) + ((g_noise > 0) - (g_noise < 0)), 0,
+          255));
+      pixel[2] = static_cast<uint8_t>(std::clamp(
+          static_cast<int>(pixel[2]) + ((b_noise > 0) - (b_noise < 0)), 0,
+          255));
+    }
+  }
+}
+
 }  // namespace
 
 constexpr char kDefaultFont[] = "10px sans-serif";
@@ -512,6 +541,9 @@ ImageData* BaseRenderingContext2D::getImageDataInternal(
           snapshot->PaintImageForCurrentFrame().GetSkImageInfo().bounds();
       DCHECK(!bounds.intersect(SkIRect::MakeXYWH(sx, sy, sw, sh)));
     }
+
+    // PureCloak: inject deterministic noise to prevent canvas fingerprinting
+    PureCloakCanvasNoise(purecloak::PureCloakNoiseTag{}, image_data_pixmap);
   }
 
   return image_data;
