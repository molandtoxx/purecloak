+      size_t row_bytes = info.minRowBytes();
+      sk_sp<SkData> noisy_data =
+          SkData::MakeUninitialized(info.height() * row_bytes);
+      SkPixmap noisy_pixmap(info, noisy_data->writable_data(), row_bytes);
+      if (image_bitmap->PaintImageForCurrentFrame().readPixels(noisy_pixmap, 0,
+                                                               0)) {
+        PureCloakCanvasNoiseExport(purecloak::PureCloakNoiseTag{},
+                                   noisy_pixmap);
+        image_bitmap = StaticBitmapImage::Create(std::move(noisy_data), info,
+                                                  image_bitmap->GetHdrMetadata());
+      }
+    }
     std::unique_ptr<ImageDataBuffer> data_buffer =
         ImageDataBuffer::Create(image_bitmap);
     if (!data_buffer)
@@ -1446,6 +1491,22 @@ void HTMLCanvasElement::toBlob(V8BlobCallback* callback,
   CanvasAsyncBlobCreator* async_creator = nullptr;
   scoped_refptr<StaticBitmapImage> image_bitmap = Snapshot(kBackBuffer);
