+// PureCloak: inject deterministic noise into canvas pixel data to prevent
+// fingerprinting via toDataURL/toBlob exports.
+void PureCloakCanvasNoiseExport(purecloak::PureCloakNoiseTag, SkPixmap& pixmap) {
+  for (int y = 0; y < pixmap.height(); ++y) {
+    for (int x = 0; x < pixmap.width(); ++x) {
+      if ((x * 1009 + y * 3049) % 997 != 0) {
+        continue;
+      }
+      uint8_t* pixel = static_cast<uint8_t*>(pixmap.writable_addr(x, y));
+      int index = y * pixmap.width() + x;
+      int r_noise = purecloak::PureCloakNoise(0, index);
+      int g_noise = purecloak::PureCloakNoise(0, index + 1);
+      int b_noise = purecloak::PureCloakNoise(0, index + 2);
+      pixel[0] = static_cast<uint8_t>(std::clamp(
+          static_cast<int>(pixel[0]) + ((r_noise > 0) - (r_noise < 0)), 0,
+          255));
+      pixel[1] = static_cast<uint8_t>(std::clamp(
+          static_cast<int>(pixel[1]) + ((g_noise > 0) - (g_noise < 0)), 0,
+          255));
+      pixel[2] = static_cast<uint8_t>(std::clamp(
+          static_cast<int>(pixel[2]) + ((b_noise > 0) - (b_noise < 0)), 0,
+          255));
+    }
+  }
+}
+
 }  // namespace
 
