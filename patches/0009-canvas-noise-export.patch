@@ -225,6 +227,39 @@ ImageData* ImageData::ValidateAndCreate(
         size_in_elements, color_type, params.zero_initialize, exception_state);
     if (!allocated_data)
       return nullptr;
+
+    // PureCloak: inject deterministic noise into constructor-allocated
+    // ImageData to prevent canvas fingerprinting detection.
+    if (color_type == kRGBA_8888_SkColorType) {
+      base::span<uint8_t> raw_bytes = allocated_data->ByteSpan();
+      for (int y = 0; y < size.height(); ++y) {
+        for (int x = 0; x < size.width(); ++x) {
+          if ((x * 1009 + y * 3049) % 997 != 0) {
+            continue;
+          }
+          int index = y * size.width() + x;
+          int byte_offset = index * 4;
+          int r_noise = purecloak::PureCloakNoise(0, index);
+          int g_noise = purecloak::PureCloakNoise(0, index + 1);
+          int b_noise = purecloak::PureCloakNoise(0, index + 2);
+          raw_bytes[byte_offset + 0] =
+              static_cast<uint8_t>(std::clamp(
+                  static_cast<int>(raw_bytes[byte_offset + 0]) +
+                      ((r_noise > 0) - (r_noise < 0)),
+                  0, 255));
+          raw_bytes[byte_offset + 1] =
+              static_cast<uint8_t>(std::clamp(
+                  static_cast<int>(raw_bytes[byte_offset + 1]) +
+                      ((g_noise > 0) - (g_noise < 0)),
+                  0, 255));
+          raw_bytes[byte_offset + 2] =
+              static_cast<uint8_t>(std::clamp(
+                  static_cast<int>(raw_bytes[byte_offset + 2]) +
+                      ((b_noise > 0) - (b_noise < 0)),
+                  0, 255));
+        }
+      }
+    }
   }
 
   return MakeGarbageCollected<ImageData>(size, data ? *data : allocated_data,
