 namespace {
 
+// PureCloak: return deterministic vendor/renderer strings using the PRNG.
+// This prevents WebGL fingerprinting from leaking actual GPU hardware info
+// while keeping the strings realistic and consistent per workspace seed.
+String PureCloakWebGLVendor() {
+  const char* kVendors[] = {
+      "Google Inc.", "Intel", "NVIDIA Corporation",
+      "Advanced Micro Devices, Inc.", "Google",
+  };
+  int idx = purecloak::PureCloakNoise(0, 100) % 5;
+  idx = (idx + 5) % 5;  // handle negative
+  return String(kVendors[idx]);
+}
+
+String PureCloakWebGLRenderer() {
+  // Generate a deterministic ANGLE-style renderer string.
+  // Different seeds produce different (but realistic) strings.
+  const char* kRenderers[] = {
+    "ANGLE (Intel, Intel(R) UHD Graphics 630 Direct3D11 vs_5_0 ps_5_0, D3D11)",
+    "ANGLE (NVIDIA, NVIDIA GeForce RTX 3060 Direct3D11 vs_5_0 ps_5_0, D3D11)",
+    "ANGLE (AMD, AMD Radeon(TM) Graphics Direct3D11 vs_5_0 ps_5_0, D3D11)",
+    "ANGLE (Google, Vulkan 1.3.0, Vulkan)",
+    "ANGLE (Intel, Intel(R) Iris(R) Xe Graphics Direct3D11 vs_5_0 ps_5_0, D3D11)",
+  };
+  int idx = purecloak::PureCloakNoise(0, 101) % 5;
+  idx = (idx + 5) % 5;
+  return String(kRenderers[idx]);
+}
+
 enum class WebGLANGLEImplementation {
