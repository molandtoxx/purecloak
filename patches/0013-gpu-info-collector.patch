From: PureCloak Authors <purecloak-dev@purecloak.org>
Date: Sat, 20 Jun 2026 14:05:00 +0800
Subject: Spoof GPU info vendor/renderer strings for anti-fingerprinting

Under PureCloak, replace the actual GL_VENDOR and GL_RENDERER strings
collected during GPU info enumeration with deterministic fake values
generated by the PureCloak PRNG. This prevents GPU fingerprinting through
APIs that expose the collected GPU info (not just WebGL getParameter).

The spoofed values are realistic and vary per workspace seed, ensuring
different workspaces produce different (but always realistic) GPU info
strings.

No BUILDFLAG guards are needed since patches only apply during
PureCloak builds.

---
 gpu/config/gpu_info_collector.cc | 22 ++++++++++++++++++++++
 1 file changed, 22 insertions(+)

diff --git a/gpu/config/gpu_info_collector.cc b/gpu/config/gpu_info_collector.cc
index a193eb0a94..12ec7169e3 100644
--- a/gpu/config/gpu_info_collector.cc
+++ b/gpu/config/gpu_info_collector.cc
@@ -26,6 +26,7 @@
 #include "build/build_config.h"
 #include "gpu/config/gpu_switches.h"
 #include "gpu/config/webgpu_blocklist_impl.h"
+#include "purecloak/common/purecloak_prng.h"
 #include "skia/buildflags.h"
 #include "third_party/abseil-cpp/absl/cleanup/cleanup.h"
 #include "third_party/angle/src/gpu_info_util/SystemInfo.h"  // nogncheck
@@ -609,6 +610,28 @@ bool CollectGraphicsInfoGL(GPUInfo* gpu_info, gl::GLDisplay* display) {
   }
   gpu_info->gl_renderer = GetGLString(GL_RENDERER);
   gpu_info->gl_vendor = GetGLString(GL_VENDOR);
+  // PureCloak: replace actual GL strings with spoofed deterministic values
+  // to prevent GPU fingerprinting. The PureCloak PRNG generates renderer and
+  // vendor strings that are consistent per workspace seed.
+  {
+    const char* kVendors[] = {
+      "Google Inc.", "Intel", "NVIDIA Corporation",
+      "Advanced Micro Devices, Inc.", "Google",
+    };
+    const char* kRenderers[] = {
+      "ANGLE (Intel, Intel(R) UHD Graphics 630 Direct3D11 vs_5_0 ps_5_0, D3D11)",
+      "ANGLE (NVIDIA, NVIDIA GeForce RTX 3060 Direct3D11 vs_5_0 ps_5_0, D3D11)",
+      "ANGLE (AMD, AMD Radeon(TM) Graphics Direct3D11 vs_5_0 ps_5_0, D3D11)",
+      "ANGLE (Google, Vulkan 1.3.0, Vulkan)",
+      "ANGLE (Intel, Intel(R) Iris(R) Xe Graphics Direct3D11 vs_5_0 ps_5_0, D3D11)",
+    };
+    int vendor_idx = purecloak::PureCloakNoise(0, 200) % 5;
+    vendor_idx = (vendor_idx + 5) % 5;
+    int renderer_idx = purecloak::PureCloakNoise(0, 201) % 5;
+    renderer_idx = (renderer_idx + 5) % 5;
+    gpu_info->gl_vendor = kVendors[vendor_idx];
+    gpu_info->gl_renderer = kRenderers[renderer_idx];
+  }
   gpu_info->gl_version = GetGLString(GL_VERSION);
   std::string glsl_version_string = GetGLString(GL_SHADING_LANGUAGE_VERSION);
 
