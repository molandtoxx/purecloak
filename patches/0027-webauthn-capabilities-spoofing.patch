From: PureCloak Authors <purecloak-dev@purecloak.org>
Date: Sat, 20 Jun 2026 19:15:00 +0800
Subject: Spoof WebAuthn platform authenticator availability

Modifies IsUVPlatformAuthenticatorAvailable to return true when
PureCloak noise is enabled, regardless of the actual platform
authenticator state. This eliminates a fingerprinting signal that
varies predictably by platform:

  - Linux → always false (no platform authenticator)
  - macOS → depends on Touch ID availability
  - Windows → depends on Windows Hello configuration

On platforms with no native platform authenticator (e.g. Linux),
adds a new implementation under IS_PURECLOAK that returns the
spoofed value. On Mac/Win/ChromeOS, adds an early-return check
before querying the real platform authenticator.

This prevents sites from detecting the operating system or
platform configuration through the WebAuthn API.

---
 content/browser/webauth/is_uvpaa.cc | 44 +++++++++++++++++++++++++++++++++++++
 1 file changed, 44 insertions(+)

diff --git a/content/browser/webauth/is_uvpaa.cc b/content/browser/webauth/is_uvpaa.cc
--- a/content/browser/webauth/is_uvpaa.cc
+++ b/content/browser/webauth/is_uvpaa.cc
@@ -11,6 +11,14 @@
 #include "content/public/browser/authenticator_request_client_delegate.h"
 #include "content/public/common/content_client.h"
 
+// PureCloak: WebAuthn platform authenticator spoofing
+#include "purecloak/common/buildflags.h"
+#if BUILDFLAG(IS_PURECLOAK)
+#include "base/command_line.h"
+#include "purecloak/common/purecloak_seed.h"
+#include "purecloak/common/purecloak_switches.h"
+#endif
+
 #if BUILDFLAG(IS_MAC)
 #include "content/public/browser/content_browser_client.h"
 #include "content/public/browser/web_authentication_delegate.h"
@@ -28,10 +36,29 @@
 
 namespace content {
 
+#if BUILDFLAG(IS_PURECLOAK)
+inline bool ShouldSpoofPlatformAuthenticator() {
+  auto* seed = purecloak::PureCloakSeed::GetInstance();
+  return seed->noise_enabled();
+}
+#else
+inline bool ShouldSpoofPlatformAuthenticator() {
+  return false;
+}
+#endif
+
 #if BUILDFLAG(IS_MAC)
 void IsUVPlatformAuthenticatorAvailable(
     BrowserContext* browser_context,
     IsUVPlatformAuthenticatorAvailableCallback callback) {
+  if (ShouldSpoofPlatformAuthenticator()) {
+    std::move(callback).Run(true);
+    return;
+  }
   const std::optional<device::fido::mac::AuthenticatorConfig> config =
       GetContentClient()
           ->browser()
@@ -48,6 +75,10 @@ void IsUVPlatformAuthenticatorAvailable(
 #elif BUILDFLAG(IS_WIN)
 void IsUVPlatformAuthenticatorAvailable(
     IsUVPlatformAuthenticatorAvailableCallback callback) {
+  if (ShouldSpoofPlatformAuthenticator()) {
+    std::move(callback).Run(true);
+    return;
+  }
   device::WinWebAuthnApiAuthenticator::
       IsUserVerifyingPlatformAuthenticatorAvailable(
           device::WinWebAuthnApi::GetDefault(), std::move(callback));
@@ -56,9 +87,22 @@ void IsUVPlatformAuthenticatorAvailable(
 #elif BUILDFLAG(IS_CHROMEOS)
 void IsUVPlatformAuthenticatorAvailable(
     IsUVPlatformAuthenticatorAvailableCallback callback) {
+  if (ShouldSpoofPlatformAuthenticator()) {
+    std::move(callback).Run(true);
+    return;
+  }
   device::ChromeOSAuthenticator::IsUVPlatformAuthenticatorAvailable(
       std::move(callback));
 }
+
+#elif BUILDFLAG(IS_PURECLOAK) && !BUILDFLAG(IS_MAC) && \
+    !BUILDFLAG(IS_WIN) && !BUILDFLAG(IS_CHROMEOS)
+void IsUVPlatformAuthenticatorAvailable(
+    IsUVPlatformAuthenticatorAvailableCallback callback) {
+  std::move(callback).Run(ShouldSpoofPlatformAuthenticator());
+}
 #endif
 
 }  // namespace content
