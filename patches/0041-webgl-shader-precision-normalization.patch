From: PureCloak Authors <purecloak-dev@purecloak.org>
Date: Sat, 20 Jun 2026 22:35:00 +0800
Subject: Normalize WebGL shader precision for deterministic fingerprinting (#14)

Overrides GLGetShaderPrecisionFormat results with fixed IEEE
single-precision values (min_range=127, max_range=127, precision=23)
when PureCloak noise is enabled. These are the values returned by a
real NVIDIA RTX 4090 for highp precision.

Without this fix, the GPU driver's shader precision values are exposed
through WebGL and can be used as a fingerprinting vector. Different GPU
vendors return different precision values (e.g., Intel integrated GPUs
may return reduced precision for mediump/lowp), and even minor
variations in driver-reported precision can distinguish one GPU model
from another.

---
 .../gpu/command_buffer/service/gles2_cmd_decoder.cc          | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/gpu/command_buffer/service/gles2_cmd_decoder.cc b/gpu/command_buffer/service/gles2_cmd_decoder.cc
index 38ebebae40..1dc0c02306 100644
--- a/gpu/command_buffer/service/gles2_cmd_decoder.cc
+++ b/gpu/command_buffer/service/gles2_cmd_decoder.cc
@@ -43,6 +43,12 @@
 #include "base/strings/stringprintf.h"
 #include "base/trace_event/trace_event.h"
 #include "build/build_config.h"
+
+#include "purecloak/common/buildflags.h"
+#if BUILDFLAG(IS_PURECLOAK)
+#include "purecloak/common/purecloak_seed.h"
+#endif
+
 #include "gpu/command_buffer/common/debug_marker_manager.h"
 #include "gpu/command_buffer/common/gles2_cmd_copy_texture_chromium_utils.h"
 #include "gpu/command_buffer/common/gles2_cmd_format.h"
@@ -14399,6 +14405,19 @@ error::Error GLES2DecoderImpl::HandleGetShaderPrecisionFormat(
   GLint precision = 0;
   QueryShaderPrecisionFormat(shader_type, precision_type, range, &precision);
 
+#if BUILDFLAG(IS_PURECLOAK)
+  // PureCloak: Normalize shader precision format values to fixed RTX 4090-class
+  // values when noise is enabled, preventing WebGL fingerprinting via
+  // glGetShaderPrecisionFormat.
+  if (purecloak::PureCloakSeed::GetInstance()->noise_enabled()) {
+    // IEEE single-precision: min_range=127, max_range=127, precision=23
+    // These are the values a real NVIDIA RTX 4090 returns for highp.
+    range[0] = 127;
+    range[1] = 127;
+    precision = 23;
+  }
+#endif
+
   result->min_range = range[0];
   result->max_range = range[1];
   result->precision = precision;
