+
+int Socks5UdpClientSocket::Write(
+    IOBuffer* buf,
+    int buf_len,
+    CompletionOnceCallback callback,
+    const NetworkTrafficAnnotationTag& traffic_annotation) {
+  DCHECK(!user_read_callback_);
+  DCHECK(!user_write_callback_);
+
+  if (closed_) {
+    return ERR_CONNECTION_CLOSED;
+  }
+
+  // Lazy SOCKS5 handshake: if Connect() was used (sync path), the SOCKS5
+  // handshake hasn't happened yet. Trigger it now.
+  if (!udp_connected_) {
+    if (next_state_ == STATE_NONE) {
+      return ERR_SOCKET_NOT_CONNECTED;
+    }
+    // Encapsulate the write data and buffer it until handshake completes.
+    scoped_refptr<IOBufferWithSize> packet =
+        BuildUDPEncapsulatedPacket(
+            reinterpret_cast<const uint8_t*>(buf->data()), buf_len);
+    write_buf_ = base::MakeRefCounted<DrainableIOBuffer>(
+        base::MakeRefCounted<WrappedIOBuffer>(packet->data()),
+        packet->size());
+    user_write_callback_ = std::move(callback);
+    int rv = DoLoop(OK);
+    if (rv == ERR_IO_PENDING) {
+      return ERR_IO_PENDING;
+    }
+    // Synchronous completion - unlikely but possible.
+    user_write_callback_.Reset();
+    write_buf_.reset();
+    if (rv != OK) {
+      return rv;
+    }
+    // Handshake complete, fall through to write.
+  }
+
+  // Build the SOCKS5 UDP encapsulated packet.
+  scoped_refptr<IOBufferWithSize> packet =
+      BuildUDPEncapsulatedPacket(reinterpret_cast<const uint8_t*>(buf->data()),
+                                  buf_len);
+
+  // Write the encapsulated packet to the UDP socket (connected to relay).
+  int rv = udp_socket_->Write(packet.get(), packet->size(),
+                               std::move(callback), traffic_annotation);
+  if (rv == ERR_IO_PENDING) {
+    user_write_callback_ = std::move(callback);
+    write_buf_ = base::MakeRefCounted<DrainableIOBuffer>(std::move(packet), packet->size());
+  }
+  return rv;
+}
