+
+int Socks5UdpClientSocket::Read(IOBuffer* buf,
+                                 int buf_len,
+                                 CompletionOnceCallback callback) {
+  DCHECK(!user_read_callback_);
+  DCHECK(!user_write_callback_);
+
+  if (!udp_connected_) {
+    return ERR_SOCKET_NOT_CONNECTED;
+  }
+
+  user_read_buf_ = buf;
+  user_read_buf_len_ = buf_len;
+  user_read_callback_ = std::move(callback);
+
+  if (!read_buf_) {
+    read_buf_ = base::MakeRefCounted<GrowableIOBuffer>();
+    read_buf_->SetCapacity(std::max(buf_len, 65536));
+  }
+
+  int rv = udp_socket_->Read(
+      read_buf_.get(), read_buf_->capacity(),
+      base::BindOnce(&Socks5UdpClientSocket::OnReadComplete,
+                     base::Unretained(this)));
+  if (rv != ERR_IO_PENDING) {
+    OnReadComplete(rv);
+  }
+  return ERR_IO_PENDING;
+}
+
+void Socks5UdpClientSocket::OnReadComplete(int result) {
+  if (result > 0 && user_read_buf_) {
+    const uint8_t* data = reinterpret_cast<const uint8_t*>(read_buf_->data());
+    int data_len = result;
+
+    // SOCKS5 UDP header: RSV(2) + FRAG(1) + ATYP(1) + DST.ADDR + DST.PORT(2)
+    // Minimum header size: 3 + 1 + 1(IPv4) + 2 = 7 bytes (with IPv4)
+    // or 3 + 1 + 16(IPv6) + 2 = 22 bytes (with IPv6)
+    if (data_len < 10) {
+      result = ERR_SOCKS_CONNECTION_FAILED;
+    } else {
+      // Skip RSV(2) + FRAG(1) = 3 bytes
+      int offset = 3;
+      uint8_t atyp = data[offset++];
+
+      // Parse DST.ADDR based on ATYP
+      switch (atyp) {
+        case 0x01:  // IPv4
+          offset += 4;
+          break;
+        case 0x04:  // IPv6
+          offset += 16;
+          break;
+        case 0x03:  // Domain name
+          if (offset >= data_len) {
+            result = ERR_SOCKS_CONNECTION_FAILED;
+          } else {
+            offset += 1 + data[offset];  // length byte + domain
+          }
+          break;
+        default:
+          result = ERR_SOCKS_CONNECTION_FAILED;
+          break;
+      }
+
+      if (result > 0) {
+        offset += 2;  // Skip DST.PORT(2)
+        if (offset > data_len) {
+          result = ERR_SOCKS_CONNECTION_FAILED;
+        } else {
+          int payload_len = data_len - offset;
+          int copy_len = std::min(payload_len, user_read_buf_len_);
+          memcpy(user_read_buf_->data(), &data[offset], copy_len);
+          result = copy_len;
+        }
+      }
+    }
+  }
+
+  CompletionOnceCallback callback = std::move(user_read_callback_);
+  user_read_buf_ = nullptr;
+  user_read_buf_len_ = 0;
+  read_buf_.reset();
+
+  if (callback) {
+    std::move(callback).Run(result);
+  }
+}
