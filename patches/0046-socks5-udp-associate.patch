+constexpr size_t kSOCKS5UDPHeaderSize = 3;  // RSV(2) + FRAG(1)
+constexpr size_t kIPv4Size = 4;
+constexpr size_t kIPv6Size = 16;
+constexpr size_t kPortSize = 2;
+
+}  // namespace
+
+Socks5UdpClientSocket::Socks5UdpClientSocket(
+    const IPEndPoint& socks_proxy_address,
+    const NetworkTrafficAnnotationTag& traffic_annotation,
+    NetLog* net_log,
+    const NetLogSource& source)
+    : socks_proxy_address_(socks_proxy_address),
+      traffic_annotation_(traffic_annotation),
+      net_log_(NetLogWithSource::Make(net_log,
+                                       NetLogSourceType::SOCKS5_CLIENT_SOCKET)),
+      io_callback_(base::BindRepeating(&Socks5UdpClientSocket::OnIOComplete,
+                                        base::Unretained(this))) {
+  net_log_.BeginEventReferencingSource(NetLogEventType::SOCKET_ALIVE, source);
+}
+
+Socks5UdpClientSocket::~Socks5UdpClientSocket() {
+  Close();
+  net_log_.EndEvent(NetLogEventType::SOCKET_ALIVE);
+}
+
+int Socks5UdpClientSocket::Connect(const IPEndPoint& address) {
+  DCHECK_EQ(STATE_NONE, next_state_);
+
+  target_address_ = address;
+
+  // Create and open the UDP socket synchronously so GetLocalAddress() and
+  // GetBoundNetwork() work immediately after Connect(). The TCP control
+  // connection and SOCKS5 handshake are deferred to the first Write().
+  udp_socket_ = std::make_unique<UDPSocket>(
+      DatagramSocket::DEFAULT_BIND, net_log_.net_log(), net_log_.source());
+  int rv = udp_socket_->Open(address.GetFamily());
+  if (rv != OK) {
+    return rv;
+  }
+  udp_socket_->GetLocalAddress(&local_address_);
+
+  next_state_ = STATE_TCP_CONNECT;
+  return OK;
+}
+
+int Socks5UdpClientSocket::ConnectAsync(const IPEndPoint& address,
+                                         CompletionOnceCallback callback) {
+  DCHECK_EQ(STATE_NONE, next_state_);
+  DCHECK(!user_connect_callback_.is_null());
+
+  target_address_ = address;
+  user_connect_callback_ = std::move(callback);
+
+  net_log_.BeginEvent(NetLogEventType::SOCKS5_CONNECT);
+
+  next_state_ = STATE_TCP_CONNECT;
+  int rv = DoLoop(OK);
+  if (rv != ERR_IO_PENDING) {
+    net_log_.EndEventWithNetErrorCode(NetLogEventType::SOCKS5_CONNECT, rv);
+    user_connect_callback_.Reset();
+  }
+  return rv;
+}
+
+int Socks5UdpClientSocket::ConnectUsingNetwork(
+    handles::NetworkHandle network,
+    const IPEndPoint& address) {
+  NOTREACHED();
+}
+
+int Socks5UdpClientSocket::ConnectUsingDefaultNetwork(
+    const IPEndPoint& address) {
+  NOTREACHED();
+}
+
+int Socks5UdpClientSocket::ConnectUsingNetworkAsync(
+    handles::NetworkHandle network,
+    const IPEndPoint& address,
+    CompletionOnceCallback callback) {
+  NOTREACHED();
+}
+
+int Socks5UdpClientSocket::ConnectUsingDefaultNetworkAsync(
+    const IPEndPoint& address,
+    CompletionOnceCallback callback) {
+  NOTREACHED();
+}
+
+void Socks5UdpClientSocket::Close() {
+  closed_ = true;
+  user_connect_callback_.Reset();
+  user_read_callback_.Reset();
+  user_write_callback_.Reset();
+
+  if (tcp_socket_) {
+    tcp_socket_->Disconnect();
+    tcp_socket_.reset();
+  }
+
+  if (udp_socket_) {
+    udp_socket_->Close();
+    udp_socket_.reset();
+  }
+
+  next_state_ = STATE_NONE;
+  socks_handshake_complete_ = false;
+  udp_connected_ = false;
+}
