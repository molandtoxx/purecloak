+
+// ---------------------------------------------------------------------------
+// SOCKS5 handshake state machine
+// ---------------------------------------------------------------------------
+
+void Socks5UdpClientSocket::DoCallback(int result) {
+  DCHECK_NE(ERR_IO_PENDING, result);
+  DCHECK(!user_connect_callback_.is_null());
+  std::move(user_connect_callback_).Run(result);
+}
+
+void Socks5UdpClientSocket::OnIOComplete(int result) {
+  DCHECK_NE(STATE_NONE, next_state_);
+  int rv = DoLoop(result);
+  if (rv != ERR_IO_PENDING) {
+    if (!user_connect_callback_.is_null()) {
+      net_log_.EndEvent(NetLogEventType::SOCKS5_CONNECT);
+      DoCallback(rv);
+    } else if (!user_write_callback_.is_null()) {
+      // Lazy-init path: SOCKS5 handshake finished, now write the buffered data
+      if (rv == OK) {
+        scoped_refptr<IOBufferWithSize> packet = BuildUDPEncapsulatedPacket(
+            reinterpret_cast<const uint8_t*>(write_buf_->data()),
+            write_buf_->BytesRemaining());
+        CompletionOnceCallback cb = std::move(user_write_callback_);
+        write_buf_.reset();
+        int write_rv = udp_socket_->Write(
+            packet.get(), packet->size(), std::move(cb), traffic_annotation_);
+        if (write_rv != ERR_IO_PENDING) {
+          // write_rv is the result but cb was consumed; nothing else to do
+        }
+      } else {
+        CompletionOnceCallback cb = std::move(user_write_callback_);
+        write_buf_.reset();
+        std::move(cb).Run(rv);
+      }
+    }
+  }
+}
+
+int Socks5UdpClientSocket::DoLoop(int result) {
+  DCHECK_NE(next_state_, STATE_NONE);
+  int rv = result;
+  do {
+    State state = next_state_;
+    next_state_ = STATE_NONE;
+    switch (state) {
+      case STATE_TCP_CONNECT:
+        DCHECK_EQ(OK, rv);
+        rv = DoTCPConnect();
+        break;
+      case STATE_TCP_CONNECT_COMPLETE:
+        rv = DoTCPConnectComplete(rv);
+        break;
+      case STATE_GREET_WRITE:
+        DCHECK_EQ(OK, rv);
+        rv = DoGreetWrite();
+        break;
+      case STATE_GREET_WRITE_COMPLETE:
+        rv = DoGreetWriteComplete(rv);
+        break;
+      case STATE_GREET_READ:
+        DCHECK_EQ(OK, rv);
+        rv = DoGreetRead();
+        break;
+      case STATE_GREET_READ_COMPLETE:
+        rv = DoGreetReadComplete(rv);
+        break;
+      case STATE_UDP_ASSOCIATE_WRITE:
+        DCHECK_EQ(OK, rv);
+        rv = DoUDPAssociateWrite();
+        break;
+      case STATE_UDP_ASSOCIATE_WRITE_COMPLETE:
+        rv = DoUDPAssociateWriteComplete(rv);
+        break;
+      case STATE_UDP_ASSOCIATE_READ:
+        DCHECK_EQ(OK, rv);
+        rv = DoUDPAssociateRead();
+        break;
+      case STATE_UDP_ASSOCIATE_READ_COMPLETE:
+        rv = DoUDPAssociateReadComplete(rv);
+        break;
+      case STATE_UDP_CONNECT:
+        DCHECK_EQ(OK, rv);
+        rv = DoUDPConnect();
+        break;
+      case STATE_UDP_CONNECT_COMPLETE:
+        rv = DoUDPConnectComplete(rv);
+        break;
+      default:
+        NOTREACHED() << "bad state " << state;
+    }
+  } while (rv != ERR_IO_PENDING && next_state_ != STATE_NONE);
+  return rv;
+}
+
+// Step 1: TCP connect to SOCKS5 proxy
+int Socks5UdpClientSocket::DoTCPConnect() {
+  DCHECK(!tcp_socket_);
+
+  next_state_ = STATE_TCP_CONNECT_COMPLETE;
+
+  tcp_socket_ = std::make_unique<TCPClientSocket>(
+      AddressList(socks_proxy_address_),
+      /*socket_performance_watcher=*/nullptr,
+      /*network_quality_estimator=*/nullptr,
+      net_log_.net_log(), net_log_.source());
+
+  return tcp_socket_->Connect(io_callback_);
+}
+
+int Socks5UdpClientSocket::DoTCPConnectComplete(int result) {
+  if (result != OK) {
+    return ERR_PROXY_CONNECTION_FAILED;
+  }
+  next_state_ = STATE_GREET_WRITE;
+  return OK;
+}
+
+// Step 2: SOCKS5 greet (no authentication)
+static constexpr std::array<uint8_t, 3> kSocks5GreetData = {0x05, 0x01, 0x00};
+
+int Socks5UdpClientSocket::DoGreetWrite() {
+  if (!write_buf_) {
+    auto greet_buffer = base::MakeRefCounted<WrappedIOBuffer>(kSocks5GreetData);
+    write_buf_ = base::MakeRefCounted<DrainableIOBuffer>(
+        std::move(greet_buffer), kSocks5GreetData.size());
+  }
+
+  next_state_ = STATE_GREET_WRITE_COMPLETE;
+  return tcp_socket_->Write(write_buf_.get(),
+                             write_buf_->BytesRemaining(), io_callback_,
+                             traffic_annotation_);
+}
+
+int Socks5UdpClientSocket::DoGreetWriteComplete(int result) {
+  if (result < 0)
+    return result;
+
+  write_buf_->DidConsume(result);
+  if (write_buf_->BytesRemaining() == 0) {
+    write_buf_.reset();
+    next_state_ = STATE_GREET_READ;
+  } else {
+    next_state_ = STATE_GREET_WRITE;
+  }
+  return OK;
+}
+
+int Socks5UdpClientSocket::DoGreetRead() {
+  next_state_ = STATE_GREET_READ_COMPLETE;
+  if (!read_buf_) {
+    read_buf_ = base::MakeRefCounted<GrowableIOBuffer>();
+    read_buf_->SetCapacity(2);
+  }
+  return tcp_socket_->Read(read_buf_.get(),
+                            read_buf_->RemainingCapacity(), io_callback_);
+}
+
+int Socks5UdpClientSocket::DoGreetReadComplete(int result) {
+  if (result < 0)
+    return result;
+
+  if (result == 0) {
+    return ERR_SOCKS_CONNECTION_FAILED;
+  }
+
+  read_buf_->set_offset(read_buf_->offset() + result);
+  if (read_buf_->RemainingCapacity() > 0) {
+    next_state_ = STATE_GREET_READ;
+    return OK;
+  }
+
+  base::span<uint8_t> read_data = read_buf_->span_before_offset();
+  if (read_data[0] != kSOCKS5Version) {
+    return ERR_SOCKS_CONNECTION_FAILED;
+  }
+  if (read_data[1] != 0x00) {
+    return ERR_SOCKS_CONNECTION_FAILED;
+  }
+
+  read_buf_.reset();
+  next_state_ = STATE_UDP_ASSOCIATE_WRITE;
+  return OK;
+}
+
+// Step 3: UDP ASSOCIATE request
+int Socks5UdpClientSocket::DoUDPAssociateWrite() {
+  next_state_ = STATE_UDP_ASSOCIATE_WRITE_COMPLETE;
+
+  if (!write_buf_) {
+    write_buf_ = BuildUDPAssociateWriteBuffer();
+  }
+
+  return tcp_socket_->Write(write_buf_.get(),
+                             write_buf_->BytesRemaining(), io_callback_,
+                             traffic_annotation_);
+}
+
+int Socks5UdpClientSocket::DoUDPAssociateWriteComplete(int result) {
+  if (result < 0)
+    return result;
+
+  write_buf_->DidConsume(result);
+  if (write_buf_->BytesRemaining() == 0) {
+    write_buf_.reset();
+    next_state_ = STATE_UDP_ASSOCIATE_READ;
+  } else {
+    next_state_ = STATE_UDP_ASSOCIATE_WRITE;
+  }
+  return OK;
+}
+
+int Socks5UdpClientSocket::DoUDPAssociateRead() {
+  next_state_ = STATE_UDP_ASSOCIATE_READ_COMPLETE;
+
+  if (!read_buf_) {
+    read_buf_ = base::MakeRefCounted<GrowableIOBuffer>();
+    read_buf_->SetCapacity(5);  // First read: version + reply + rsv + atyp
+  }
+
+  return tcp_socket_->Read(read_buf_.get(),
+                            read_buf_->RemainingCapacity(), io_callback_);
+}
+
+int Socks5UdpClientSocket::DoUDPAssociateReadComplete(int result) {
+  if (result < 0)
+    return result;
+
+  if (result == 0) {
+    return ERR_SOCKS_CONNECTION_FAILED;
+  }
+
+  read_buf_->set_offset(read_buf_->offset() + result);
+
+  // Need at least 5 bytes: ver + rep + rsv + atyp
+  if (read_buf_->offset() < 5) {
+    next_state_ = STATE_UDP_ASSOCIATE_READ;
+    return OK;
+  }
+
+  base::span<uint8_t> read_data = read_buf_->span_before_offset();
+
+  // Check version, reply code, and reserved byte
+  if (read_data[0] != kSOCKS5Version || read_data[2] != kNullByte) {
+    return ERR_SOCKS_CONNECTION_FAILED;
+  }
+  if (read_data[1] != 0x00) {
+    return ERR_SOCKS_CONNECTION_FAILED;
+  }
+
+  // Parse the relay address type and determine expected size
+  uint8_t address_type = read_data[3];
+  int address_size = 0;
+
+  switch (address_type) {
+    case 0x01:  // IPv4
+      address_size = kIPv4Size;
+      break;
+    case 0x04:  // IPv6
+      address_size = kIPv6Size;
+      break;
+    case 0x03:  // Domain name
+      if (read_buf_->offset() < 6) {
+        next_state_ = STATE_UDP_ASSOCIATE_READ;
+        return OK;
+      }
+      address_size = read_data[4];
+      break;
+    default:
+      return ERR_SOCKS_CONNECTION_FAILED;
+  }
+
+  int total_needed = 5 + address_size + kPortSize;
+  if (address_type == 0x03) {
+    total_needed = 4 + 1 + address_size + kPortSize;
+  }
+
+  if (read_buf_->offset() < total_needed) {
+    read_buf_->SetCapacity(total_needed);
+    next_state_ = STATE_UDP_ASSOCIATE_READ;
+    return OK;
+  }
+
+  // Extract the relay address from the response.
+  IPAddress relay_ip;
+  int port_offset = 0;
+
+  if (address_type == 0x01) {
+    relay_ip = IPAddress(read_data[4], read_data[5], read_data[6], read_data[7]);
+    port_offset = 8;
+  } else if (address_type == 0x04) {
+    std::array<uint8_t, kIPv6Size> ipv6_bytes;
+    memcpy(ipv6_bytes.data(), &read_data[4], kIPv6Size);
+    relay_ip = IPAddress(ipv6_bytes);
+    port_offset = 4 + kIPv6Size;
+  } else {
+    // Domain name - skip the domain bytes
+    port_offset = 4 + 1 + address_size;
+    // Use the proxy address for relay if we can't parse domain
+    relay_ip = socks_proxy_address_.address();
+  }
+
+  uint16_t relay_port = base::U16FromBigEndian(
+      base::span(read_data.subspan(port_offset, 2)));
+
+  relay_address_ = IPEndPoint(relay_ip, relay_port);
+
+  read_buf_.reset();
+  next_state_ = STATE_UDP_CONNECT;
+  return OK;
+}
+
+// Step 4: Create and connect UDP socket to relay
+int Socks5UdpClientSocket::DoUDPConnect() {
+  next_state_ = STATE_UDP_CONNECT_COMPLETE;
+
+  udp_socket_ = std::make_unique<UDPSocket>(
+      DatagramSocket::DEFAULT_BIND, net_log_.net_log(), net_log_.source());
+
+  int rv = udp_socket_->Open(relay_address_.GetFamily());
+  if (rv != OK) {
+    return rv;
+  }
+
+  rv = udp_socket_->Connect(relay_address_);
+  if (rv != OK) {
+    return rv;
+  }
+
+  // Get the local address of the UDP socket for GetLocalAddress().
+  udp_socket_->GetLocalAddress(&local_address_);
+
+  udp_connected_ = true;
+  socks_handshake_complete_ = true;
+  next_state_ = STATE_CONNECTED;
+  return OK;
+}
+
+int Socks5UdpClientSocket::DoUDPConnectComplete(int result) {
+  return result;
+}
+
+// ---------------------------------------------------------------------------
+// SOCKS5 packet builders
+// ---------------------------------------------------------------------------
+
+scoped_refptr<DrainableIOBuffer>
+Socks5UdpClientSocket::BuildUDPAssociateWriteBuffer() {
+  // UDP ASSOCIATE request:
+  // +----+------+------+----------+----------+----------+
+  // |VER | CMD |  RSV |  ATYP   | BND.ADDR | BND.PORT |
+  // +----+------+------+----------+----------+----------+
+  // | 1  |  1  |  1   |    1    | Variable |    2     |
+  // +----+------+------+----------+----------+----------+
+  //
+  // We use IPv4 0.0.0.0:0 to let the proxy choose the relay address.
+  std::vector<uint8_t> request;
+  request.reserve(10);
+  request.push_back(kSOCKS5Version);
+  request.push_back(kUDPAssociateCommand);
+  request.push_back(kNullByte);
+  request.push_back(0x01);  // IPv4
+  request.push_back(0x00);  // 0.0.0.0
+  request.push_back(0x00);
+  request.push_back(0x00);
+  request.push_back(0x00);
+  request.push_back(0x00);  // Port: 0
+  request.push_back(0x00);
+
+  auto base_buffer = base::MakeRefCounted<VectorIOBuffer>(std::move(request));
+  return base::MakeRefCounted<DrainableIOBuffer>(std::move(base_buffer),
+                                                  base_buffer->size());
+}
+
+scoped_refptr<IOBufferWithSize>
+Socks5UdpClientSocket::BuildUDPEncapsulatedPacket(const uint8_t* data,
+                                                   int data_len) {
+  // SOCKS5 UDP request header:
+  // +----+------+------+----------+----------+----------+
+  // |RSV | FRAG | ATYP | DST.ADDR | DST.PORT |   DATA   |
+  // +----+------+------+----------+----------+----------+
+  // | 2  |  1   |  1   | Variable |    2     | Variable |
+  // +----+------+------+----------+----------+----------+
+
+  const IPAddress& target_ip = target_address_.address();
+  uint16_t target_port = target_address_.port();
+
+  int addr_size = target_ip.IsIPv4() ? kIPv4Size : kIPv6Size;
+  int header_size = kSOCKS5UDPHeaderSize + 1 + addr_size + kPortSize;
+  int total_size = header_size + data_len;
+
+  auto packet = base::MakeRefCounted<IOBufferWithSize>(total_size);
+  uint8_t* buf = packet->data();
+
+  int offset = 0;
+  buf[offset++] = 0x00;  // RSV
+  buf[offset++] = 0x00;
+  buf[offset++] = 0x00;  // FRAG
+
+  if (target_ip.IsIPv4()) {
+    buf[offset++] = 0x01;  // ATYP: IPv4
+    memcpy(&buf[offset], target_ip.bytes().data(), kIPv4Size);
+    offset += kIPv4Size;
+  } else {
+    buf[offset++] = 0x04;  // ATYP: IPv6
+    memcpy(&buf[offset], target_ip.bytes().data(), kIPv6Size);
+    offset += kIPv6Size;
+  }
+
+  buf[offset++] = static_cast<uint8_t>(target_port >> 8);
+  buf[offset++] = static_cast<uint8_t>(target_port & 0xFF);
+
+  memcpy(&buf[offset], data, data_len);
+
+  return packet;
+}
